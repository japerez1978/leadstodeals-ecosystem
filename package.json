{
  "name": "leadstodeals-ecosystem",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "core-saas",
    "leadstodeals-scoring",
    "leadstodeals-admin",
    "intranox-ofertas",
    "sats-saltoki",
    "calculadora-fee"
  ],
  "scripts": {
    "build": "echo 'Use a project-specific build script: build:sats, build:scoring, build:admin, build:ofertas, build:fee' && exit 1",
    "install-all": "npm install",
    "dev:proxy": "npm --prefix services/intranox-proxy run dev",
    "start:proxy": "npm --prefix services/intranox-proxy run start",
    "build:scoring": "npm run build -w leadstodeals-scoring",
    "build:admin": "npm run build -w leadstodeals-admin",
    "build:ofertas": "npm run build -w intranox-ofertas",
    "build:sats": "npm run build -w sats-saltoki",
    "build:fee": "npm run build -w calculadora-fee",
    "build:all": "npm run build:sats && npm run build:scoring && npm run build:admin && npm run build:ofertas && npm run build:fee"
  }
}
